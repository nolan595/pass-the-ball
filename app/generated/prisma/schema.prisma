generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DisplayType {
  ONE_X_TWO
  OVER_UNDER
  ONE_FROM_TWO
  PLAYER_PROPS
  PLAYER_PROPS_SINGLE
}

model Market {
  id               Int         @id @default(autoincrement())
  name             String
  marketId         Int         @unique
  displayType      DisplayType
  enabled          Boolean     @default(true)
  superSubEligible Boolean     @default(false)
  createdAt        DateTime    @default(now())

  @@map("markets")
}

model ExternalEvent {
  id              Int       @id @default(autoincrement())
  name            String
  externalEventId String    @unique
  matchDate       DateTime?
  createdAt       DateTime  @default(now())

  games Game[]

  @@map("external_events")
}

enum GameStatus {
  DRAFT
  PENDING
  OPEN
  CLOSED
  COMPLETED
}

enum PrizeType {
  CASH
  FREE_BET
}

model Game {
  id            Int           @id @default(autoincrement())
  name          String
  eventId       Int
  event         ExternalEvent @relation(fields: [eventId], references: [id])
  status        GameStatus    @default(DRAFT)
  openTime      DateTime
  closeTime     DateTime
  prizeType     PrizeType
  bonusId       String?
  multiplier    Float         @default(1.0)
  s3Status      String?
  paymentStatus String?
  sgaUuid       String?
  sgaPrice      Float?
  sgaStatus     String?
  createdAt     DateTime      @default(now())

  picks Pick[]

  @@map("games")
}

model Player {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  displayName String
  createdAt   DateTime @default(now())

  picks Pick[]

  @@map("players")
}

model Pick {
  id         Int      @id @default(autoincrement())
  gameId     Int
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerId   Int
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  marketId   Int
  oddUuid    String
  oddName    String
  marketName String
  oddPrice   Float
  createdAt  DateTime @default(now())

  @@unique([gameId, playerId])
  @@map("picks")
}
